{
	"name": "@qnaplus/updater",
	"private": true,
	"version": "1.0.0",
	"description": "",
	"main": "dist/index.js",
	"author": "battlesqui_d",
	"license": "GPL-3.0",
	"scripts": {
		"start": "node dist/index.js",
		"dev": "node dist/index.js",
		"build": "tsc",
		"build:production": "tsc --declaration false --noCheck true",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf dist tsconfig.tsbuildinfo",
		"clean:modules": "rm -rf node_modules",
		"clean:full": "pnpm clean && pnpm clean:modules",
		"lint": "oxlint src",
		"lint:fix": "oxlint --fix src",
		"fmt": "oxfmt --check src",
		"fmt:fix": "oxfmt src",
		"update_storage": "tsx scripts/update_storage.ts | pino-pretty"
	},
	"dependencies": {
		"@qnaplus/dotenv": "workspace:*",
		"@qnaplus/logger": "workspace:*",
		"@qnaplus/scraper": "catalog:",
		"@qnaplus/scraper-strategies": "catalog:",
		"@qnaplus/store": "workspace:*",
		"@qnaplus/utils": "workspace:*",
		"croner": "catalog:"
	},
	"devDependencies": {
		"@qnaplus/typescript-config": "workspace:*",
		"pino": "catalog:",
		"pino-pretty": "catalog:"
	},
	"volta": {
		"extends": "../../package.json"
	}
}
