{
	"name": "@qnaplus/store",
	"private": true,
	"version": "1.0.0",
	"description": "",
	"author": "battlesqui_d",
	"license": "GPL-3.0",
	"scripts": {
		"build": "tsc",
		"build:production": "tsc --declaration false --noCheck true",
		"clean": "rm -rf dist tsconfig.tsbuildinfo",
		"clean:modules": "rm -rf node_modules",
		"clean:full": "pnpm clean && pnpm clean:modules",
		"lint": "oxlint src",
		"lint:fix": "oxlint --fix src",
		"fmt": "oxfmt --check src",
		"fmt:fix": "oxfmt src",
		"populate": "tsx scripts/populate.ts | pino-pretty",
		"populate_metadata": "tsx scripts/populate.ts --metadata | pino-pretty",
		"check-types": "tsc --noEmit",
		"db:push": "drizzle-kit push",
		"db:gen": "drizzle-kit generate"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1047.0",
		"@qnaplus/dotenv": "workspace:*",
		"@qnaplus/scraper": "catalog:",
		"@qnaplus/utils": "workspace:*",
		"drizzle-orm": "^0.45.2",
		"pino": "catalog:",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@qnaplus/scraper-strategies": "catalog:",
		"@qnaplus/typescript-config": "workspace:*",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "catalog:"
	},
	"exports": {
		".": {
			"default": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"volta": {
		"extends": "../../package.json"
	}
}
